.env
.env.

# ----------------------------
# Data files (keep repo lightweight)
# ----------------------------
data/raw/
data/interim/
data/processed/
data/synthetic/*
src/data_generation/data/synthetic/*.csv



# Allow placeholder files so folders exist
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep

# ----------------------------
# Large reports or outputs
# ----------------------------
reports/figures/*
reports/tables/*
docs/*.pdf

!reports/figures/.gitkeep
!reports/tables/.gitkeep

# ----------------------------
# Misc
